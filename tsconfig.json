{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@whisperweave/core": ["packages/core/src/index.ts"],
      "@whisperweave/core/*": ["packages/core/src/*"],
      "@/*": ["apps/web/src/*"]
    }
  },
  "include": [
    "packages/core/src/**/*.ts",
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx"
  ]
}
