# 复制为 .env.local 后填入真实凭证。所有 key 仅在服务端 API Route 使用，不暴露给浏览器。

# LLM 提供商: openai | anthropic | deepseek | qwen | zhipu | openai-compatible
LLM_PROVIDER=openai

# OpenAI / OpenAI 兼容
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 通义千问 (OpenAI 兼容)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# 智谱 (OpenAI 兼容)
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash

# 飞书开放平台应用凭证
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 同步目标文件夹 token（云空间根目录留空）。在飞书云文档对应文件夹 URL 里取 folderToken
FEISHU_FOLDER_TOKEN=
